## Code for Encryption
#include <stdio.h>
#include <string.h>
int main(){
    char st[] = "Aaj to monday hai";
    for (int i = 0;  i < strlen(st); i++) {
        st[i] = st[i] + 1;
    }
    printf("%s", st);
    return 0;
}
## Code for Decryption
#include <stdio.h>
